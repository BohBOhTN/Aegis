generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Core Users & Security (RBAC & Tracing)
// -----------------------------------------------------------------------------
model Role {
  id          String    @id @default(uuid())
  name        String    @unique
  permissions Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users       User[]

  @@map("roles")
}

model User {
  id           String    @id @default(uuid())
  roleId       String
  email        String    @unique
  passwordHash String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogs    AuditLog[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  oldData    Json?
  newData    Json?
  timestamp  DateTime @default(now())

  // If a user is hard deleted, logs should remain for security, but users are soft-deleted.
  // Using Restrict prevents deleting users who have logs associated.
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("audit_logs")
}

// -----------------------------------------------------------------------------
// Directory (Clients & Suppliers)
// -----------------------------------------------------------------------------
enum ClientType {
  B2B
  B2C
}

model Client {
  id              String     @id @default(uuid())
  type            ClientType
  companyName     String
  matriculeFiscal String?
  address         String?
  phone           String?
  email           String?    @unique
  balance         Decimal    @default(0.00) @db.Decimal(10, 3)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  documents       Document[]
  payments        Payment[]

  @@map("clients")
}

model Supplier {
  id          String    @id @default(uuid())
  companyName String
  contactName String?
  phone       String?
  email       String?   @unique
  address     String?
  balanceDue  Decimal   @default(0.00) @db.Decimal(10, 3)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("suppliers")
}

// -----------------------------------------------------------------------------
// Catalog & Stock Infrastructure
// -----------------------------------------------------------------------------
model Product {
  id            String    @id @default(uuid())
  barcode       String?   @unique
  name          String
  category      String?
  purchasePrice Decimal   @db.Decimal(10, 3)
  sellingPrice  Decimal   @db.Decimal(10, 3)
  minThreshold  Decimal   @default(0.00) @db.Decimal(10, 3)
  taxRate       Decimal   @default(19.00) @db.Decimal(5, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  inventory     InventoryLevel[]
  movements     InventoryMovement[]
  documentLines DocumentLine[]

  @@map("products")
}

model Warehouse {
  id        String    @id @default(uuid())
  name      String
  location  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  pos       PointOfSale[]
  inventory InventoryLevel[]

  @@map("warehouses")
}

model PointOfSale {
  id          String    @id @default(uuid())
  name        String
  warehouseId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@map("points_of_sale")
}

model InventoryLevel {
  productId   String
  warehouseId String
  quantity    Decimal  @default(0.00) @db.Decimal(10, 3)
  updatedAt   DateTime @updatedAt

  product     Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@id([productId, warehouseId])
  @@map("inventory_levels")
}

enum MovementType {
  PURCHASE
  TRANSFER
  SALE
  ADJUSTMENT
}

model InventoryMovement {
  id          String       @id @default(uuid())
  productId   String
  fromLoc     String?      
  toLoc       String?      
  quantity    Decimal      @db.Decimal(10, 3)
  type        MovementType
  timestamp   DateTime     @default(now())

  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("inventory_movements")
}

// -----------------------------------------------------------------------------
// Core Transactions & Financial Documents
// -----------------------------------------------------------------------------
enum DocumentType {
  DEVIS
  BC
  BL
  FACTURE
  AVOIR
}

enum DocumentStatus {
  DRAFT
  VALIDATED
  PAID
  CANCELLED
}

model Document {
  id            String         @id @default(uuid())
  documentNum   String         @unique
  type          DocumentType
  status        DocumentStatus @default(DRAFT)
  clientId      String
  totalHT       Decimal        @default(0.00) @db.Decimal(10, 3)
  tva           Decimal        @default(0.00) @db.Decimal(10, 3)
  timbreFiscal  Decimal        @default(1.00) @db.Decimal(10, 3)
  totalTTC      Decimal        @default(0.00) @db.Decimal(10, 3)
  issueDate     DateTime       @default(now())
  dueDate       DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  client        Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  lines         DocumentLine[]
  payments      Payment[]

  @@map("documents")
}

model DocumentLine {
  id         String   @id @default(uuid())
  documentId String
  productId  String
  quantity   Decimal  @db.Decimal(10, 3)
  unitPrice  Decimal  @db.Decimal(10, 3)
  totalPrice Decimal  @db.Decimal(10, 3)

  // Cascade delete is permitted here: if a draft Document is permanently deleted, its lines vanish.
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("document_lines")
}

model Payment {
  id         String   @id @default(uuid())
  documentId String
  clientId   String
  amount     Decimal  @db.Decimal(10, 3)
  method     String   
  date       DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Restrict)
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@map("payments")
}

// -----------------------------------------------------------------------------
// Global Application Configuration
// -----------------------------------------------------------------------------
model AppSettings {
  id                String   @id @default(uuid())
  companyName       String
  legalInfo         String?
  timbreFiscalPrice Decimal  @default(1.00) @db.Decimal(10, 3)
  defaultTva        Decimal  @default(19.00) @db.Decimal(5, 2)
  updatedAt         DateTime @updatedAt

  @@map("app_settings")
}
