generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Core Users & Security (RBAC & Tracing)
// -----------------------------------------------------------------------------
model Role {
  id          String    @id @default(uuid())
  name        String    @unique
  permissions Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users User[]

  @@map("roles")
}

model User {
  id           String    @id @default(uuid())
  roleId       String
  email        String    @unique
  passwordHash String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  role      Role                @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogs AuditLog[]
  movements InventoryMovement[]
  expenses  Expense[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  oldData    Json?
  newData    Json?
  timestamp  DateTime @default(now())

  // If a user is hard deleted, logs should remain for security, but users are soft-deleted.
  // Using Restrict prevents deleting users who have logs associated.
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("audit_logs")
}

// -----------------------------------------------------------------------------
// Directory (Clients & Suppliers)
// -----------------------------------------------------------------------------
enum ClientType {
  B2B
  B2C
}

model Client {
  id              String     @id @default(uuid())
  type            ClientType
  companyName     String
  matriculeFiscal String?
  address         String?
  phone           String?
  email           String?    @unique
  balance         Decimal    @default(0.00) @db.Decimal(10, 3)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  documents Document[]
  payments  Payment[]

  @@map("clients")
}

model Supplier {
  id                String             @id @default(uuid())
  companyName       String
  contactName       String?
  phone             String?
  email             String?            @unique
  address           String?
  balanceDue        Decimal            @default(0.00) @db.Decimal(10, 3)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  purchaseDocuments PurchaseDocument[]
  supplierPayments  SupplierPayment[]

  @@map("suppliers")
}

// -----------------------------------------------------------------------------
// Catalog & Stock Infrastructure
// -----------------------------------------------------------------------------
model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@map("categories")
}

model Unit {
  id        String    @id @default(uuid())
  name      String    @unique
  symbol    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products Product[]

  @@map("units")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model PriceHistory {
  id               String   @id @default(uuid())
  productId        String
  oldPurchasePrice Decimal  @db.Decimal(10, 3)
  newPurchasePrice Decimal  @db.Decimal(10, 3)
  oldSellingPrice  Decimal  @db.Decimal(10, 3)
  newSellingPrice  Decimal  @db.Decimal(10, 3)
  reason           String?
  changedByUserId  String?
  createdAt        DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("price_history")
}

model Product {
  id            String    @id @default(uuid())
  barcode       String?   @unique
  name          String
  categoryId    String?
  unitId        String?
  purchasePrice Decimal   @db.Decimal(10, 3)
  sellingPrice  Decimal   @db.Decimal(10, 3)
  minThreshold  Decimal   @default(0.00) @db.Decimal(10, 3)
  taxRate       Decimal   @default(19.00) @db.Decimal(5, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  category     Category?      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  unit         Unit?          @relation(fields: [unitId], references: [id], onDelete: Restrict)
  images       ProductImage[]
  priceHistory PriceHistory[]

  warehouseStock WarehouseInventory[]
  posStock       PosInventory[]
  movements      InventoryMovement[]
  documentLines  DocumentLine[]
  purchaseLines  PurchaseDocumentLine[]

  @@map("products")
}

model Warehouse {
  id        String    @id @default(uuid())
  name      String
  location  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  pos       PointOfSale[]
  inventory WarehouseInventory[]

  @@map("warehouses")
}

model PointOfSale {
  id          String    @id @default(uuid())
  name        String
  warehouseId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  inventory PosInventory[]

  @@map("points_of_sale")
}

model WarehouseInventory {
  productId    String
  warehouseId  String
  quantity     Decimal  @default(0.00) @db.Decimal(10, 3)
  minThreshold Decimal? @db.Decimal(10, 3)
  updatedAt    DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@id([productId, warehouseId])
  @@map("warehouse_inventory")
}

model PosInventory {
  productId    String
  posId        String
  quantity     Decimal  @default(0.00) @db.Decimal(10, 3)
  minThreshold Decimal? @db.Decimal(10, 3)
  updatedAt    DateTime @updatedAt

  product Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  pos     PointOfSale @relation(fields: [posId], references: [id], onDelete: Restrict)

  @@id([productId, posId])
  @@map("pos_inventory")
}

enum MovementType {
  PURCHASE
  TRANSFER
  SALE
  ADJUSTMENT
}

model InventoryMovement {
  id              String       @id @default(uuid())
  productId       String
  fromWarehouseId String?
  fromPosId       String?
  toWarehouseId   String?
  toPosId         String?
  quantity        Decimal      @db.Decimal(10, 3)
  type            MovementType
  description     String?
  createdByUserId String? // Tracks the User who performed the action
  timestamp       DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  user    User?   @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@map("inventory_movements")
}

// -----------------------------------------------------------------------------
// Supplier Workflows (Goods Reception & Financials)
// -----------------------------------------------------------------------------
enum PurchaseDocumentType {
  BON_COMMANDE
  BON_RECEPTION
  FACTURE_FOURNISSEUR
}

enum PurchaseStatus {
  DRAFT
  VALIDATED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model PurchaseDocument {
  id          String               @id @default(uuid())
  documentNum String               @unique
  type        PurchaseDocumentType
  status      PurchaseStatus       @default(DRAFT)
  supplierId  String

  receivedAtWarehouseId String?
  receivedAtPosId       String?

  totalHT    Decimal @default(0.00) @db.Decimal(10, 3)
  tva        Decimal @default(0.00) @db.Decimal(10, 3)
  totalTTC   Decimal @default(0.00) @db.Decimal(10, 3)
  amountPaid Decimal @default(0.00) @db.Decimal(10, 3)

  issueDate   DateTime  @default(now())
  dueDate     DateTime?
  documentUrl String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  supplier Supplier               @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  lines    PurchaseDocumentLine[]
  payments SupplierPayment[]

  @@map("purchase_documents")
}

model PurchaseDocumentLine {
  id                 String  @id @default(uuid())
  purchaseDocumentId String
  productId          String
  quantity           Decimal @db.Decimal(10, 3)
  unitPrice          Decimal @db.Decimal(10, 3)
  totalPrice         Decimal @db.Decimal(10, 3)

  purchaseDoc PurchaseDocument @relation(fields: [purchaseDocumentId], references: [id], onDelete: Cascade)
  product     Product          @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("purchase_document_lines")
}

model SupplierPayment {
  id                 String   @id @default(uuid())
  purchaseDocumentId String
  supplierId         String
  amount             Decimal  @db.Decimal(10, 3)
  method             String
  date               DateTime @default(now())

  purchaseDoc PurchaseDocument @relation(fields: [purchaseDocumentId], references: [id], onDelete: Restrict)
  supplier    Supplier         @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  @@map("supplier_payments")
}

// -----------------------------------------------------------------------------
// Core Client Transactions & Financial Documents
// -----------------------------------------------------------------------------
enum DocumentType {
  DEVIS
  BC
  BL
  FACTURE
  AVOIR
}

enum DocumentStatus {
  DRAFT
  VALIDATED
  PAID
  CANCELLED
}

model Document {
  id          String         @id @default(uuid())
  documentNum String         @unique
  type        DocumentType
  status      DocumentStatus @default(DRAFT)
  clientId    String

  dispatchFromWarehouseId String?
  dispatchFromPosId       String?

  totalHT      Decimal   @default(0.00) @db.Decimal(10, 3)
  tva          Decimal   @default(0.00) @db.Decimal(10, 3)
  timbreFiscal Decimal   @default(1.00) @db.Decimal(10, 3)
  totalTTC     Decimal   @default(0.00) @db.Decimal(10, 3)
  issueDate    DateTime  @default(now())
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  client   Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  lines    DocumentLine[]
  payments Payment[]

  @@map("documents")
}

model DocumentLine {
  id         String  @id @default(uuid())
  documentId String
  productId  String
  quantity   Decimal @db.Decimal(10, 3)
  unitPrice  Decimal @db.Decimal(10, 3)
  totalPrice Decimal @db.Decimal(10, 3)

  // Cascade delete is permitted here: if a draft Document is permanently deleted, its lines vanish.
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("document_lines")
}

model Payment {
  id         String   @id @default(uuid())
  documentId String
  clientId   String
  amount     Decimal  @db.Decimal(10, 3)
  method     String
  date       DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Restrict)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@map("payments")
}

// -----------------------------------------------------------------------------
// Global Application Configuration
// -----------------------------------------------------------------------------
model AppSettings {
  id                String   @id @default(uuid())
  companyName       String
  matriculeFiscal   String?
  address           String?
  phone             String?
  email             String?
  legalInfo         String?
  timbreFiscalPrice Decimal  @default(1.00) @db.Decimal(10, 3)
  defaultTva        Decimal  @default(19.00) @db.Decimal(5, 2)
  updatedAt         DateTime @updatedAt

  @@map("app_settings")
}

// -----------------------------------------------------------------------------
// Treasury (Expenses)
// -----------------------------------------------------------------------------
model ExpenseCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  expenses Expense[]

  @@map("expense_categories")
}

model Expense {
  id               String    @id @default(uuid())
  categoryId       String
  amount           Decimal   @db.Decimal(10, 3)
  description      String
  receiptUrl       String?
  date             DateTime  @default(now())
  recordedByUserId String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  user     User            @relation(fields: [recordedByUserId], references: [id], onDelete: Restrict)

  @@map("expenses")
}
